# =============================================================
# Ikizere Funds — Environment Configuration
# =============================================================
# Copy this file to .env and fill in the values for your server.
# The app reads these via getenv(); if a variable is missing,
# the fallback default in config/config.php is used.
# =============================================================

# ---------- Database ----------
DB_HOST=127.0.0.1
DB_NAME=ikizere_funds
DB_USER=root
DB_PASS=
DB_PORT=3306

# ---------- Application ----------
APP_URL=http://localhost/ikizere_funds
APP_NAME=IKIZERE FUNDS Club

# ---------- Debug (set to 1 ONLY in local development) ----------
APP_DEBUG=0

# =============================================================
# RAILWAY DEPLOYMENT
# =============================================================
# When deploying on Railway, set these as environment variables
# in the Railway dashboard (Settings → Variables):
#
#   DB_HOST  = ${{MySQL.MYSQLHOST}}
#   DB_PORT  = ${{MySQL.MYSQLPORT}}
#   DB_NAME  = ${{MySQL.MYSQL_DATABASE}}
#   DB_USER  = ${{MySQL.MYSQL_USER}}
#   DB_PASS  = ${{MySQL.MYSQL_PASSWORD}}
#   APP_URL  = https://your-app.up.railway.app
#   APP_DEBUG = 0
#
# Railway auto-injects MySQL variables when you add a MySQL
# database service to your project.
# =============================================================
