# =============================================================
# Ikizere Funds — Environment Configuration
# =============================================================
# Copy this file to .env and fill in values for local dev.
# On Railway: just set variables in the dashboard — everything
# else is handled automatically.
# =============================================================

# ---------- Database ----------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=ikizere_funds
DB_USER=root
DB_PASS=

# ---------- Application ----------
APP_URL=http://localhost/ikizere_funds

# ---------- Debug (set to 1 ONLY in local development) ----------
APP_DEBUG=0

# =============================================================
# RAILWAY: Zero-Config Deployment
# =============================================================
# 1. Connect your GitHub repo on railway.app
# 2. Add a MySQL database (New → Database → MySQL)
# 3. That's it! Railway auto-injects MYSQL_* variables and the
#    app auto-creates the database + default admin on first boot.
#
# Default admin credentials (change after first login):
#   Username : admin
#   Password : Admin@12345
#
# To customize the default admin, set these env vars:
#   ADMIN_NAME  = Your Name
#   ADMIN_USER  = myadmin
#   ADMIN_PASS  = MySecurePass123!
#   ADMIN_EMAIL = you@example.com
#   ADMIN_PHONE = +250700000000
# =============================================================
